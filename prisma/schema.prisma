// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id          String   @id @default(cuid())
  cin         String   @unique
  firstName   String
  lastName    String
  email       String?
  phone       String
  address     String?
  city        String?
  licenseNum  String?
  licenseExp  DateTime?
  isBlacklist Boolean  @default(false)
  blacklistReason String?
  blacklistedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations Reservation[]
  rentals      Rental[]
  infractions  Infraction[]
}

model Vehicle {
  id              String   @id @default(cuid())
  plate           String   @unique
  brand           String
  model           String
  year            Int
  category        String   // ECONOMY, COMFORT, LUXURY, SUV, VAN
  color           String
  fuelType        String   // DIESEL, ESSENCE, HYBRID, ELECTRIC
  transmission    String   // MANUAL, AUTOMATIC
  seats           Int      @default(5)
  dailyRate       Float
  status          String   @default("AVAILABLE") // AVAILABLE, RENTED, MAINTENANCE, OUT_OF_SERVICE
  mileage         Int      @default(0)
  lastOilChangeMileage Int @default(0)
  nextOilChangeMileage Int @default(10000)
  technicalInspectionDate DateTime?
  insuranceExpiry DateTime?
  vignetteExpiry  DateTime?
  notes           String?
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservations Reservation[]
  rentals      Rental[]
  damageLogs   DamageLog[]
  expenses     Expense[]
}

model Reservation {
  id          String   @id @default(cuid())
  refCode     String   @unique
  clientId    String
  vehicleId   String
  startDate   DateTime
  endDate     DateTime
  totalAmount Float
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, CONVERTED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  rental  Rental?
}

model Rental {
  id              String   @id @default(cuid())
  contractNum     String   @unique
  clientId        String
  vehicleId       String
  reservationId   String?  @unique
  startDate       DateTime
  endDate         DateTime
  returnDate      DateTime?
  dailyRate       Float
  totalDays       Int
  totalAmount     Float
  deposit         Float    @default(0)
  depositReturned Boolean  @default(false)
  fuelLevelStart  String   @default("FULL") // EMPTY, QUARTER, HALF, THREE_QUARTER, FULL
  fuelLevelEnd    String?
  mileageStart    Int
  mileageEnd      Int?
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  contractPdfUrl  String?
  notes           String?
  extras          String?  // JSON string of extra charges
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client      Client      @relation(fields: [clientId], references: [id])
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  payments    Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  rentalId  String
  amount    Float
  method    String   // CASH, CARD, TRANSFER, CHEQUE
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  rental Rental @relation(fields: [rentalId], references: [id])
}

model DamageLog {
  id          String   @id @default(cuid())
  vehicleId   String
  description String
  severity    String   // MINOR, MODERATE, SEVERE
  zone        String   // FRONT, REAR, LEFT, RIGHT, TOP, INTERIOR
  repaired    Boolean  @default(false)
  repairCost  Float?
  detectedAt  DateTime @default(now())
  repairedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  vehicleId   String?
  category    String   // MAINTENANCE, FUEL, INSURANCE, CLEANING, REPAIR, OTHER
  description String
  amount      Float
  date        DateTime
  vendor      String?
  receipt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Infraction {
  id          String   @id @default(cuid())
  clientId    String
  type        String   // SPEEDING, PARKING, DAMAGE, LATE_RETURN, OTHER
  description String
  amount      Float?
  date        DateTime
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
